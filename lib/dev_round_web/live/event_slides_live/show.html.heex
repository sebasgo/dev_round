<Layouts.app flash={@flash} current_user={@current_user}>
  <.breadcrumbs items={[:events, @event]} />
  <.header>
    Live Presentation
    <:actions>
      <.button
        id="show-slides-fullscreen-btn"
        class="btn btn-primary flex content-center gap-3"
        phx-hook="ShowFullScreen"
        data-target="fullscreen-container"
      >
        <.icon name="hero-arrows-pointing-out" class="w-5 h-5" /> Show Fullscreen
      </.button>
    </:actions>
  </.header>

  <div
    id="fullscreen-container"
    class={[
      "bg-base-300 text-base rounded-lg [:fullscreen]:rounded-none shadow-lg overflow-hidden my-8",
      @session != nil && "aspect-video"
    ]}
  >
    <%= if @event.live do %>
      <%= if @session != nil do %>
        <.live_component
          module={DevRoundWeb.EventSessionTeamsSlideLive}
          id={"teams-#{@session.id}"}
          event_session={@session}
          new_event_session?={@new_session?}
          multiple_langs={@multiple_langs}
        />
      <% else %>
        <.live_component
          module={DevRoundWeb.EventSlidesViewerLive}
          id={@event.id}
          event={@event}
          controls={false}
          fullscreen_wrapper_id="fullscreen-container"
        />
      <% end %>
    <% else %>
      <svg width="0" height="0">
        <filter id="noise-filter">
          <feTurbulence
            type="fractalNoise"
            baseFrequency="0.8"
            numOctaves="3"
            stitchTiles="stitch"
          />
        </filter>
      </svg>
      <div class="relative">
        <div class="w-full aspect-[16/9] opacity-25" style="filter: url(#noise-filter)"></div>
        <div class="absolute inset-0 flex w-full h-full items-center justify-center">
          <p class="text-base-content">There is currently no live presentation for this event</p>
        </div>
      </div>
    <% end %>
  </div>

  <.usage_hint>
    You can follow the presentation through the slides here. Audio is not provided.
  </.usage_hint>
</Layouts.app>
