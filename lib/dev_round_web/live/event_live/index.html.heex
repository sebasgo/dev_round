<Layouts.app flash={@flash} current_user={@current_user}>
  <.header class="mb-8">
    Events
    <:subtitle>Discover current and archived events</:subtitle>
  </.header>

  <.form for={@search_form} id="search-from" phx-change="search" class="mb-12">
    <label class="input w-full">
      <.icon name="hero-magnifying-glass" class="w-4 h-4" />
      <input
        type="search"
        name={@search_form[:query][:name]}
        id={@search_form[:query][:id]}
        value={@search_form[:query][:value]}
        class="grow"
        placeholder="Search"
      />
    </label>
  </.form>

  <%= if @search_results != nil do %>
    <DevRoundWeb.EventComponents.event_grid_listing
      events={@search_results}
      title="Search Results"
      accent_class="primary"
    >
      <:placeholder>
        <DevRoundWeb.EventComponents.content_placeholder title="No search results.">
          Try a different search term.
        </DevRoundWeb.EventComponents.content_placeholder>
      </:placeholder>
    </DevRoundWeb.EventComponents.event_grid_listing>
  <% else %>
    <DevRoundWeb.EventComponents.event_grid_listing
      events={@current_events}
      title="Current Events"
      accent_class="primary"
    >
      <:placeholder>
        <DevRoundWeb.EventComponents.content_placeholder title="No current events.">
          Check back soon for new events!
        </DevRoundWeb.EventComponents.content_placeholder>
      </:placeholder>
    </DevRoundWeb.EventComponents.event_grid_listing>

    <DevRoundWeb.EventComponents.event_grid_listing
      :if={not Enum.empty?(@archived_events)}
      events={@archived_events}
      title="Archived Events"
      accent_class="neutral"
    />
  <% end %>
</Layouts.app>
