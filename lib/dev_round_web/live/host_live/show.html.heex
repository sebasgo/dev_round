<.header>
  Host «{@event.title}»
</.header>

<.table id="attendees" rows={@event.events_attendees}>
  <:col :let={attendee} label="Status">
    <.icon :if={attendee.checked} name="hero-check-circle" class="w-8 h-8 text-success" aria-label="Checked"/>
  </:col>
  <:col :let={attendee} label="Participant">
    <.user_badge user={attendee.user} remote={attendee.is_remote} expierence_level={attendee.expierence_level}>
      <p :if={!Enum.empty?(tl(@event.langs))} class="text-sm">
        <%= Enum.map(attendee.langs, fn lang -> lang.name end) |> Enum.intersperse(", ") %>
      </p>
    </.user_badge>
  </:col>
  <:col :let={attendee} label="Registration">
    {attendee.inserted_at |> DateTime.shift_zone!(DevRound.Formats.time_zone()) |> DevRound.Formats.format_datetime()}
  </:col>
  <:action :let={attendee}>
    <.button 
      class="btn btn-success flex gap-2"
      disabled={attendee.checked}
      phx-click={JS.push("checkin", value: %{id: attendee.id})}
    >
      <.icon name="hero-check-circle" class="w-4 h-4"/>
      Check in
    </.button>
  </:action>
  <:action :let={attendee}>
    <.button 
      class="btn btn-warning flex gap-2"
      disabled={!attendee.checked}
      phx-click={JS.push("checkout", value: %{id: attendee.id})}
    >
      <.icon name="hero-x-circle" class="w-4 h-4"/>
      Check out
    </.button>
  </:action>
</.table>
