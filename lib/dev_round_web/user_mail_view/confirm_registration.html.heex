<.layout_html>
    <p>
    Dear {@user.full_name},
    </p>

    <p>
    We are thrilled to confirm your registration for <.link href={url(~p"/events/#{@event}")}><em>{@event.title}</em></.link>:
    </p>


    <dl>
        <dt>Date and time:</dt>
        <dd>{DevRound.Formats.format_datetime_range(@event.begin, @event.end)}</dd>
        <dt>Location:</dt>
        <dd>{@event.location}</dd>
    </dl>

    <p>
    You can update your registration details or cancel your registration at any time via the
    <.link href={url(~p"/events/#{@event}/registration/edit")}>registration form</.link>.
    </p>

    <p>
    Best, <br/>
    <%= Enum.map(@event.hosts, fn host -> host.full_name end) |> Enum.intersperse(" & ") %>
    </p>
</.layout_html>

